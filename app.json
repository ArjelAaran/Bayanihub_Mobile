{
  "expo": {
    "name": "BayaniHub Mobile",
    "slug": "bayanihub-mobile",
    "scheme": "bayanihub",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "predictiveBackGestureEnabled": true
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
